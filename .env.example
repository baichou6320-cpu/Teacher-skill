# =============================================================================
# API Configuration - Teacher-skill
# =============================================================================

# API Key (required) - 获取地址: https://console.anthropic.com/ 或 https://platform.moonshot.cn/
ANTHROPIC_API_KEY=your_api_key_here

# Base URL (optional, default uses Anthropic official API)
# Kimi/Moonshot: https://api.moonshot.cn/anthropic
# Anthropic 官方: https://api.anthropic.com (or leave empty)
ANTHROPIC_BASE_URL=

# Model and generation settings are configured in config.yaml:
# llm.model_id, llm.temperature, llm.max_tokens, etc.
# Note: MODEL_ID is intentionally not defined here because the runtime reads
# the model from config.yaml.

# =============================================================================
