# =============================================================================
# API Configuration - Teacher-skill
# =============================================================================

# Recommended setup:
#   python main.py --setup
#
# Generic API key used by all supported providers:
# - Anthropic: https://console.anthropic.com/
# - Kimi/Moonshot: https://platform.moonshot.cn/
# - DeepSeek: https://platform.deepseek.com/
TEACHER_SKILL_API_KEY=your_api_key_here

# Base URL is optional for Anthropic official API and required for
# OpenAI-compatible providers. The setup wizard fills this automatically.
# Kimi/Moonshot: https://api.moonshot.cn/v1
# DeepSeek: https://api.deepseek.com
TEACHER_SKILL_BASE_URL=

# Legacy variable names are still accepted for compatibility.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# Model and generation settings are configured in config.yaml:
# llm.provider, llm.api_format, llm.base_url, llm.model_id, etc.
# Note: MODEL_ID is intentionally not defined here because the runtime reads
# the model from config.yaml.

# =============================================================================
